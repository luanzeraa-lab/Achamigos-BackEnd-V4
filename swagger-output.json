  "paths": {
    "/": {
      "get": {
        "description": "Rota inicial",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },

    "/api/gerartexto": {
      "post": {
        "description": "Gera texto usando IA",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  },
                  "nome": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Solicitação Inválida"
          }
        }
      }
    },

    "/api/animais": {
      "get": {
        "description": "Lista animais",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "description": "Cria animal",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "idade": {
                    "type": "number"
                  },
                  "raca": {
                    "type": "string"
                  },
                  "sexo": {
                    "type": "string"
                  },
                  "porte": {
                    "type": "string"
                  },
                  "peso": {
                    "type": "number"
                  },
                  "observacoes": {
                    "type": "string"
                  },
                  "linkAnimal": {
                    "type": "string"
                  },
                  "castracao": {
                    "type": "boolean"
                  },
                  "tipo": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Criado"
          }
        }
      }
    },

