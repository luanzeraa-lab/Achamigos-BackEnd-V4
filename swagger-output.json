        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "idade": {
                    "type": "number"
                  },
                  "raca": {
                    "type": "string"
                  },
                  "sexo": {
                    "type": "string"
                  },
                  "porte": {
                    "type": "string"
                  },
                  "peso": {
                    "type": "number"
                  },
                  "observacoes": {
                    "type": "string"
                  },
                  "linkAnimal": {
                    "type": "string"
