      },
      "post": {
        "description": "Cria usuário",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "cnpj": {
                    "type": "string"
                  },
                  "telefone": {
                    "type": "string"
                  },
                  "userLogin": {
                    "type": "string"
                  },
                  "senha": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "linkUser": {
                    "type": "string"
                  },
                  "endereco": {
                    "type": "object",
                    "properties": {
                      "cep": {
                        "type": "string"
                      },
                      "rua": {
                        "type": "string"
                      },
                      "cidade": {
                        "type": "string"
                      },
                      "numero": {
                        "type": "string"
                      }
